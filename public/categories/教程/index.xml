      <description>&lt;p&gt;import {&#xA;useState, useReducer, useEffect, useLayoutEffect,&#xA;useRef, useCallback, useMemo, useContext,&#xA;createContext, useTransition, useDeferredValue, useId,&#xA;useDebugValue&#xA;} from &amp;ldquo;react&amp;rdquo;;&lt;/p&gt;&#xA;&lt;p&gt;// ============================================================&#xA;// useContext + createContext — 全局主题管理&#xA;// ============================================================&#xA;const ThemeContext = createContext();&lt;/p&gt;&#xA;&lt;p&gt;// ============================================================&#xA;// useReducer — 复杂状态管理（任务的增删改查）&#xA;// ============================================================&#xA;const initialTasks = [&#xA;{ id: 1, text: &amp;ldquo;学习 React Hooks&amp;rdquo;, done: true, priority: &amp;ldquo;high&amp;rdquo; },&#xA;{ id: 2, text: &amp;ldquo;构建任务管理应用&amp;rdquo;, done: false, priority: &amp;ldquo;high&amp;rdquo; },&#xA;{ id: 3, text: &amp;ldquo;阅读官方文档&amp;rdquo;, done: false, priority: &amp;ldquo;medium&amp;rdquo; },&#xA;{ id: 4, text: &amp;ldquo;写单元测试&amp;rdquo;, done: false, priority: &amp;ldquo;low&amp;rdquo; },&#xA;];&lt;/p&gt;</description>
