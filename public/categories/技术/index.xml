      <title>前端开发：难点、框架体系与工程师核心能力</title>
      <link>https://fridacai.vercel.app/blog/%E5%89%8D%E7%AB%AF%E5%BC%80%E5%8F%91%E9%9A%BE%E7%82%B9%E6%A1%86%E6%9E%B6%E4%BD%93%E7%B3%BB%E4%B8%8E%E5%B7%A5%E7%A8%8B%E5%B8%88%E6%A0%B8%E5%BF%83%E8%83%BD%E5%8A%9B/</link>
