    <item>
      <title>Next.js 网站结构详解</title>
      <link>http://localhost:1313/blog/2026/03/next.js-%E7%BD%91%E7%AB%99%E7%BB%93%E6%9E%84%E8%AF%A6%E8%A7%A3/</link>
