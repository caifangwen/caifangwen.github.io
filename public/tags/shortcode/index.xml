    <item>
      <title>WordPress 自定义短代码实现子页面卡片列表</title>
      <link>http://localhost:1313/blog/2026/03/wordpress-%E8%87%AA%E5%AE%9A%E4%B9%89%E7%9F%AD%E4%BB%A3%E7%A0%81%E5%AE%9E%E7%8E%B0%E5%AD%90%E9%A1%B5%E9%9D%A2%E5%8D%A1%E7%89%87%E5%88%97%E8%A1%A8/</link>
