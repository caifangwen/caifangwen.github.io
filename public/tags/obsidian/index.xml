      <link>http://localhost:1313/blog/2026/03/obsidian-cli-%E5%AE%98%E6%96%B9%E5%91%BD%E4%BB%A4%E8%A1%8C%E7%95%8C%E9%9D%A2%E4%BB%8B%E7%BB%8D/</link>
